{
  "name": "lspilot",
  "displayName": "LSPilot",
  "description": "Copilot-like inline completions powered by LM Studio.",
  "version": "0.0.1",
  "publisher": "raph559",
  "license": "MIT",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:lspilot.chatView",
    "onCommand:lspilot.openChat",
    "onCommand:lspilot.selectModel",
    "onCommand:lspilot.clearChat",
    "onCommand:lspilot.triggerInlineCompletion",
    "onCommand:lspilot.testConnection"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lspilot.openChat",
        "title": "LSPilot: Open Chat"
      },
      {
        "command": "lspilot.selectModel",
        "title": "LSPilot: Select Model"
      },
      {
        "command": "lspilot.clearChat",
        "title": "LSPilot: Clear Chat"
      },
      {
        "command": "lspilot.triggerInlineCompletion",
        "title": "LSPilot: Trigger Inline Completion"
      },
      {
        "command": "lspilot.testConnection",
        "title": "LSPilot: Test LM Studio Connection"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lspilotSidebar",
          "title": "LSPilot",
          "icon": "media/lspilot.svg"
        }
      ]
    },
    "views": {
      "lspilotSidebar": [
        {
          "id": "lspilot.chatView",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "LSPilot",
      "properties": {
        "lspilot.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable LSPilot inline completions."
        },
        "lspilot.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:1234/v1",
          "description": "LM Studio OpenAI-compatible API base URL."
        },
        "lspilot.model": {
          "type": "string",
          "default": "",
          "description": "Model ID to use. Leave empty for no selected model."
        },
        "lspilot.temperature": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature for inline completions."
        },
        "lspilot.maxTokens": {
          "type": "number",
          "default": 96,
          "minimum": 8,
          "maximum": 1024,
          "description": "Maximum completion tokens returned by LM Studio."
        },
        "lspilot.timeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 1000,
          "maximum": 120000,
          "description": "Request timeout in milliseconds."
        },
        "lspilot.chatTimeoutMs": {
          "type": "number",
          "default": 60000,
          "minimum": 1000,
          "maximum": 600000,
          "description": "Timeout in milliseconds for chat responses."
        },
        "lspilot.modelLoadTimeoutMs": {
          "type": "number",
          "default": 180000,
          "minimum": 5000,
          "maximum": 600000,
          "description": "Timeout in milliseconds when loading a model in LM Studio."
        },
        "lspilot.minRequestGapMs": {
          "type": "number",
          "default": 300,
          "minimum": 0,
          "maximum": 5000,
          "description": "Minimum delay between requests for the same document."
        },
        "lspilot.maxLines": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "maximum": 64,
          "description": "Maximum number of lines in one inline completion."
        },
        "lspilot.chatMaxTokens": {
          "type": "number",
          "default": 512,
          "minimum": 32,
          "maximum": 4096,
          "description": "Maximum token budget for chat responses."
        },
        "lspilot.systemPrompt": {
          "type": "string",
          "default": "You are a coding assistant that returns only the next code continuation. Do not explain. Do not wrap output in markdown fences.",
          "description": "System prompt for completion behavior."
        },
        "lspilot.chatSystemPrompt": {
          "type": "string",
          "default": "You are a helpful coding assistant inside VS Code. Give direct, practical answers with runnable code when useful.",
          "description": "System prompt for chat behavior."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p .",
    "watch": "tsc -w -p .",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/marked": "^5.0.2",
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.88.0",
    "typescript": "^5.4.5",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "marked": "^17.0.3",
    "marked-highlight": "^2.2.3"
  }
}
